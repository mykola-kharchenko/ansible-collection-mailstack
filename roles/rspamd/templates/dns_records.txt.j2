# {{ ansible_managed }}
# Publish these records in each domain's authoritative DNS zone.
{% for r in _mailstack_dkim_pub.results %}

; ===== {{ r.item }} =====
; DKIM
{{ mailstack_rspamd_dkim_selector }}._domainkey.{{ r.item }}. IN TXT "v=DKIM1; k=rsa; p={{ r.stdout }}"
; SPF — adjust to your sending hosts
{{ r.item }}. IN TXT "v=spf1 mx -all"
; DMARC
_dmarc.{{ r.item }}. IN TXT "v=DMARC1; p=quarantine; rua=mailto:postmaster@{{ r.item }}"
{% endfor %}
